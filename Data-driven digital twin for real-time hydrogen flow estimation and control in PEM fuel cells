# 5.  MODEL DEFINITION
# ─────────────────────────────────────────────────────────────────────────────
class ResidualBlock(nn.Module):
    """ResNet-style block: skip connection + BN + GELU + Dropout"""
    def __init__(self, dim: int, dropout: float):
        super().__init__()
        self.net = nn.Sequential(
            nn.Linear(dim, dim), nn.BatchNorm1d(dim), nn.GELU(), nn.Dropout(dropout),
            nn.Linear(dim, dim), nn.BatchNorm1d(dim),
        )
        self.act = nn.GELU()

    def forward(self, x):
        return self.act(x + self.net(x))


class PEMNet(nn.Module):
    """Residual NN for PEM fuel-cell anode flow regression."""
    def __init__(self, input_dim: int, hidden: int = 768,
                 n_res: int = 4, dropout: float = 0.15):
        super().__init__()
        self.stem = nn.Sequential(
            nn.Linear(input_dim, hidden), nn.BatchNorm1d(hidden),
            nn.GELU(), nn.Dropout(dropout),
        )
        self.res_blocks = nn.Sequential(
            *[ResidualBlock(hidden, dropout) for _ in range(n_res)]
        )
        self.head = nn.Sequential(
            nn.Linear(hidden, 128), nn.GELU(), nn.Linear(128, 1),
        )

    def forward(self, x):
        return self.head(self.res_blocks(self.stem(x)))


