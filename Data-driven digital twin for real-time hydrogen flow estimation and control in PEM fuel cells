# 6.  DATA LOADERS
# ─────────────────────────────────────────────────────────────────────────────
PIN      = torch.cuda.is_available()
N_WORKERS = 4 if torch.cuda.is_available() else 0

def make_loader(X_arr, y_ser, shuffle=True, batch=None):
    if batch is None:
        batch = AUTO_BATCH
    ds = TensorDataset(
        torch.tensor(X_arr, dtype=torch.float32),
        torch.tensor(y_ser.values, dtype=torch.float32).unsqueeze(1),
    )
    return DataLoader(ds, batch_size=batch, shuffle=shuffle,
                      pin_memory=PIN, num_workers=N_WORKERS,
                      persistent_workers=(N_WORKERS > 0))

train_loader = make_loader(X_tr_s, y_tr)
val_loader   = make_loader(X_v_s,  y_v,  shuffle=False)
test_loader  = make_loader(X_te_s, y_te, shuffle=False)


# ─────────────────────────────────────────────────────────────────────────────
# 7.  TRAINING HELPER
# ─────────────────────────────────────────────────────────────────────────────
PATIENCE = 10

def run_training(params: dict, epochs: int, verbose: bool = False):
    m   = PEMNet(X_tr_s.shape[1], params['hidden'],
                 params['n_res'],  params['dropout']).to(device)
    opt  = optim.AdamW(m.parameters(), lr=params['lr'], weight_decay=params['wd'])
    sch  = optim.lr_scheduler.CosineAnnealingLR(opt, T_max=epochs)
    crit = nn.HuberLoss(delta=1.0)

    best_val_mae = float('inf')
    best_state   = None
    pat_cnt      = 0
    history      = {'train_loss': [], 'val_mae': [], 'val_r2': []}

    for epoch in range(1, epochs + 1):
        m.train()
        total_loss = 0.0
        for bx, by in train_loader:
            bx = bx.to(device, non_blocking=True)
            by = by.to(device, non_blocking=True)
            opt.zero_grad(set_to_none=True)
            if USE_AMP:
                with torch.cuda.amp.autocast():
                    loss = crit(m(bx), by)
                amp_scaler.scale(loss).backward()
                amp_scaler.unscale_(opt)
                nn.utils.clip_grad_norm_(m.parameters(), 1.0)
                amp_scaler.step(opt); amp_scaler.update()
            else:
                loss = crit(m(bx), by)
                loss.backward()
                nn.utils.clip_grad_norm_(m.parameters(), 1.0)
                opt.step()
            total_loss += loss.item()
        sch.step()

        # ── validation ──────────────────────────────────────────────
        m.eval()
        pv = []
        with torch.no_grad():
            for bx, _ in val_loader:
                bx = bx.to(device, non_blocking=True)
                if USE_AMP:
                    with torch.cuda.amp.autocast():
                        pv.append(m(bx).cpu().numpy())
                else:
                    pv.append(m(bx).cpu().numpy())
        pv       = np.concatenate(pv).flatten()
        val_mae  = mean_absolute_error(y_v, pv)
        val_r2   = r2_score(y_v, pv)

        history['train_loss'].append(total_loss / len(train_loader))
        history['val_mae'].append(val_mae)
        history['val_r2'].append(val_r2)

        if val_mae < best_val_mae:
            best_val_mae = val_mae
            best_state   = {k: v.cpu().clone() for k, v in m.state_dict().items()}
            pat_cnt      = 0
        else:
            pat_cnt += 1
            if pat_cnt >= PATIENCE:
                if verbose:
                    print(f'      Early stop at epoch {epoch}')
                break

        if verbose and epoch % 10 == 0:
            print(f'      Ep {epoch:3d}  loss={total_loss/len(train_loader):.4f}'
                  f'  val_MAE={val_mae:.4f}  val_R²={val_r2:.6f}')

    m.load_state_dict(best_state)
    return m, best_val_mae, history


